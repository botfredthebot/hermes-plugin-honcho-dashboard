{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-shadow": "error",
    "no-unused-vars": "warn",
    "no-undef": "warn",
    "no-redeclare": "error"
  },
  "globals": {
    "window": "readonly",
    "document": "readonly",
    "console": "readonly",
    "React": "readonly"
  }
}
